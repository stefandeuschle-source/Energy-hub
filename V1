  .skill-panel { margin-top: 10px; background: #f7fafc; border: 1px solid #e3eaf0; border-radius: 8px; padding: 10px 12px 8px; }
  .skill-head { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
  .skill-head .sk-label { font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--mp-grey); }
  .skill-head .sk-val { font-size: 19px; font-weight: 800; }
  .sk-strong { color: var(--green); } .sk-mid { color: #d98a13; } .sk-weak { color: var(--red); }
  .skill-box { position: relative; height: 110px; }
  .mt { margin-top: 14px; }
  .badge { display: inline-block; font-size: 9.5px; font-weight: 700; padding: 2px 8px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.7px; }
  .badge.high { background: rgba(192,57,43,0.12); color: var(--red); }
  .badge.med { background: rgba(248,169,58,0.18); color: #b57310; }
  .badge.low { background: rgba(30,142,90,0.12); color: var(--green); }
</style>
