      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { boxWidth: 12, font: { size: 11 } } },
        tooltip: { callbacks: { label: ctx => ctx.dataset.label.split(' (')[0] + ': index ' + ctx.parsed.y } } },
      scales: {
        y: { min: 80, max: 180, grid: { color: '#edf2f6' } },
        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
      }
    }
  });
  evDataset = outlookChart.data.datasets[3];
} catch(e) { console.error('Scenario engine chart failed to render:', e); }

function updateEV() {
  const wA = +document.getElementById('pA').value;
  const wB = +document.getElementById('pB').value;
  const wC = +document.getElementById('pC').value;
  const total = (wA + wB + wC) || 1;
  const nA = Math.round(wA/total*100), nB = Math.round(wB/total*100);
  const nC = 100 - nA - nB;
  document.getElementById('pAv').textContent = nA + '%';
  document.getElementById('pBv').textContent = nB + '%';
  document.getElementById('pCv').textContent = nC + '%';
  const path = evPath(wA, wB, wC);
  const endpoint = path[path.length - 1];
  document.getElementById('ev-endpoint').textContent = 'Index ' + endpoint;
  if (outlookChart && evDataset) {
    evDataset.data = path;
    outlookChart.data.datasets[0].label = 'A · Normalization (' + nA + '%)';
    outlookChart.data.datasets[1].label = 'B · Constrained flow (' + nB + '%)';
    outlookChart.data.datasets[2].label = 'C · Escalation (' + nC + '%)';
    outlookChart.update('none');
  }
}
['pA','pB','pC'].forEach(id => {
  const el = document.getElementById(id);
  if (el) el.addEventListener('input', updateEV);
});
updateEV();
</script>
</body>
</html>
