  .t-item.red::before { background: var(--red); box-shadow: 0 0 0 2px var(--red); }
  .t-item.orange::before { background: var(--mp-orange); box-shadow: 0 0 0 2px var(--mp-orange); }
  .t-item .t-date { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--mp-teal); }
  .t-item.red .t-date { color: var(--red); }
  .t-item.orange .t-date { color: #d98a13; }
  .t-item .t-text { font-size: 12.5px; color: #34506b; line-height: 1.55; margin-top: 2px; }

  .chart-box { position: relative; height: 300px; }
  .chart-box.tall { height: 340px; }

  /* scenario cards */
  .scen { border-top: 4px solid var(--mp-teal); }
  .scen.base { border-top-color: var(--mp-orange); }
  .scen.bear { border-top-color: var(--red); }
