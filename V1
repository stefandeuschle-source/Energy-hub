<title>Energy Situation Analysis Framework</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root {
    --mp-dark: #10395c;
    --mp-darker: #081530;
    --mp-teal: #078b95;
    --mp-orange: #f8a93a;
    --mp-lightblue: #61a0d6;
    --mp-lightgrey: #e8eef2;
    --mp-cream: #f9f6ee;
    --mp-grey: #8c8c8c;
    --red: #c0392b;
    --green: #1e8e5a;
    --card-radius: 10px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Figtree', 'Segoe UI', -apple-system, sans-serif;
    background: #f2f5f8;
    color: var(--mp-dark);
    display: flex;
    min-height: 100vh;
  }

  /* ============ SIDEBAR ============ */
  .sidebar {
    width: 235px;
    min-width: 235px;
    background: linear-gradient(180deg, var(--mp-dark) 0%, var(--mp-darker) 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
  }
  .logo { padding: 22px 20px 18px; border-bottom: 1px solid rgba(255,255,255,0.12); }
  .logo .brand { font-weight: 800; letter-spacing: 1px; font-size: 15px; }
  .logo .brand span { color: var(--mp-teal); }
  .logo .sub { font-size: 10px; color: rgba(255,255,255,0.55); margin-top: 3px; text-transform: uppercase; letter-spacing: 1.2px; }
  .nav { flex: 1; padding: 14px 0; overflow-y: auto; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 20px; font-size: 13px;
    color: rgba(255,255,255,0.72);
    cursor: pointer; border-left: 3px solid transparent;
    transition: background 0.15s;
    user-select: none;
  }
  .nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .nav-item.active {
    background: rgba(7,139,149,0.22);
    border-left-color: var(--mp-teal);
    color: #fff; font-weight: 600;
  }
  .nav-item .ico { width: 18px; text-align: center; font-size: 14px; }
  .nav-section-label {
    padding: 16px 20px 6px; font-size: 10px; text-transform: uppercase;
    letter-spacing: 1.4px; color: rgba(255,255,255,0.38);
  }
  .sidebar-footer {
    padding: 14px 20px; font-size: 10px; color: rgba(255,255,255,0.4);
    border-top: 1px solid rgba(255,255,255,0.12);
    line-height: 1.5;
  }

  /* ============ MAIN ============ */
  .main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  .topbar {
    background: #fff; padding: 14px 28px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid #dde5ec;
    position: sticky; top: 0; z-index: 50;
  }
  .topbar h1 { font-size: 17px; font-weight: 700; color: var(--mp-dark); }
  .topbar .meta { font-size: 11px; color: var(--mp-grey); text-align: right; line-height: 1.5; }
  .topbar .meta b { color: var(--mp-teal); }

  .status-banner {
    background: linear-gradient(90deg, var(--mp-dark), #14507e);
    color: #fff; padding: 10px 28px; font-size: 12.5px;
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .status-banner .pill {
    background: var(--mp-orange); color: var(--mp-darker);
    font-weight: 700; font-size: 10px; text-transform: uppercase;
    letter-spacing: 1px; padding: 3px 10px; border-radius: 20px;
  }

  .content { padding: 24px 28px 60px; flex: 1; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; animation: fadeIn 0.25s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px);} to { opacity: 1; transform: none;} }

  h2.section-title {
    font-size: 12px; text-transform: uppercase; letter-spacing: 1.6px;
    color: var(--mp-teal); font-weight: 700; margin: 26px 0 12px;
  }
  h2.section-title:first-child { margin-top: 0; }
  .lede { font-size: 13px; color: #3d5a75; max-width: 960px; margin-bottom: 16px; line-height: 1.65; }

  /* ============ CARDS / GRID ============ */
  .grid { display: grid; gap: 14px; }
  .g6 { grid-template-columns: repeat(6, 1fr); }
  .g5 { grid-template-columns: repeat(5, 1fr); }
  .g4 { grid-template-columns: repeat(4, 1fr); }
  .g3 { grid-template-columns: repeat(3, 1fr); }
  .g2 { grid-template-columns: repeat(2, 1fr); }
  @media (max-width: 1250px) { .g6, .g5 { grid-template-columns: repeat(3, 1fr);} .g4 { grid-template-columns: repeat(2, 1fr);} }
  @media (max-width: 860px) {
    .g6, .g5, .g4, .g3, .g2 { grid-template-columns: 1fr; }
    .sidebar { display: none; }
  }

  .card {
    background: #fff; border-radius: var(--card-radius);
    padding: 16px 18px;
    box-shadow: 0 1px 3px rgba(16,57,92,0.08);
    border: 1px solid #e3eaf0;
  }
  .kpi .label { font-size: 10.5px; text-transform: uppercase; letter-spacing: 1px; color: var(--mp-grey); font-weight: 600; }
  .kpi .value { font-size: 22px; font-weight: 800; color: var(--mp-dark); margin: 6px 0 2px; }
  .kpi .value.teal { color: var(--mp-teal); }
  .kpi .value.orange { color: #d98a13; }
  .kpi .value.red { color: var(--red); }
  .kpi .delta { font-size: 11.5px; color: var(--mp-grey); line-height: 1.45; }
  .kpi .delta .up { color: var(--red); font-weight: 700; }
  .kpi .delta .down { color: var(--green); font-weight: 700; }

  .card h3 { font-size: 14.5px; font-weight: 700; color: var(--mp-dark); margin-bottom: 8px; }
  .card p { font-size: 12.5px; line-height: 1.6; color: #3d5a75; }
  .card .src { font-size: 10px; color: var(--mp-grey); margin-top: 10px; display: block; border-top: 1px dashed #e0e8ef; padding-top: 7px; }

  /* method cards */
  .method-card { position: relative; overflow: hidden; }
  .method-card .m-num {
    position: absolute; top: -8px; right: 6px; font-size: 64px; font-weight: 800;
    color: var(--mp-lightgrey); z-index: 0; line-height: 1;
  }
  .method-card > * { position: relative; z-index: 1; }
  .method-tag {
    display: inline-block; font-size: 9.5px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; padding: 3px 9px; border-radius: 4px; margin-bottom: 8px;
    background: rgba(7,139,149,0.12); color: var(--mp-teal);
  }
  .sm-step { display: flex; gap: 8px; margin-top: 8px; font-size: 12px; line-height: 1.55; color: #3d5a75; }
  .sm-step .sm-key {
    min-width: 96px; font-size: 9.5px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.8px; color: var(--mp-teal); padding-top: 2px;
  }
  .signal-row {
    display: flex; align-items: center; gap: 8px; margin-top: 12px;
    background: var(--mp-lightgrey); border-radius: 6px; padding: 9px 12px;
  }
  .signal-row .sig-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--mp-grey); font-weight: 700; }
  .signal-row .sig-val { font-size: 12.5px; font-weight: 700; }
  .sig-bear { color: var(--red); } .sig-neut { color: #d98a13; } .sig-bull { color: var(--green); }

  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  th { text-align: left; padding: 8px 10px; background: var(--mp-lightgrey); color: var(--mp-dark); font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.8px; }
  td { padding: 8px 10px; border-bottom: 1px solid #edf2f6; color: #34506b; vertical-align: top; }
  tr:last-child td { border-bottom: none; }
  td b { color: var(--mp-dark); }

  /* pipeline */
  .pipeline { display: flex; gap: 0; align-items: stretch; flex-wrap: wrap; }
  .pipe-step {
    flex: 1; min-width: 130px; background: #fff; border: 1px solid #e3eaf0;
    padding: 14px 12px; position: relative; text-align: center;
  }
  .pipe-step:first-child { border-radius: 10px 0 0 10px; }
  .pipe-step:last-child { border-radius: 0 10px 10px 0; }
  .pipe-step .p-num {
    width: 26px; height: 26px; border-radius: 50%; background: var(--mp-teal); color: #fff;
    font-size: 12px; font-weight: 800; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 8px;
  }
  .pipe-step h4 { font-size: 12px; font-weight: 700; color: var(--mp-dark); margin-bottom: 4px; }
  .pipe-step p { font-size: 10.5px; color: #5a748c; line-height: 1.45; }
  .pipe-step::after {
    content: '→'; position: absolute; right: -8px; top: 50%; transform: translateY(-50%);
    color: var(--mp-teal); font-weight: 800; z-index: 2; background: transparent;
  }
  .pipe-step:last-child::after { display: none; }

  /* timeline */
  .timeline { position: relative; padding-left: 22px; }
  .timeline::before { content: ''; position: absolute; left: 6px; top: 4px; bottom: 4px; width: 2px; background: #d6e0e9; }
  .t-item { position: relative; padding: 0 0 16px 12px; }
  .t-item::before {
    content: ''; position: absolute; left: -21px; top: 4px; width: 12px; height: 12px;
    border-radius: 50%; background: var(--mp-teal); border: 2.5px solid #fff;
    box-shadow: 0 0 0 2px var(--mp-teal);
