/* ============ PREDICTIVE SKILL: COMPUTED BACKTESTS ============ */
/* Each rule emits +1 (predict target up next month), -1 (down) or 0 (no signal) using only
   data available at month t. A hit = sign(target[t+1] - target[t]) matches the signal.
   Bars = rolling 12-month hit rate over signal months (min 3 signals in window). */

function backtest(target, signalFn) {
  const n = target.length;
  const hits = new Array(n).fill(null); /* 1 hit, 0 miss, null no signal */
  for (let t = 2; t < n - 1; t++) {
    const s = signalFn(t);
    if (s === 0) continue;
    const move = target[t + 1] - target[t];
    if (move === 0) continue;
    hits[t] = (Math.sign(move) === s) ? 1 : 0;
  }
  const rolling = new Array(n).fill(null);
  for (let t = 12; t < n; t++) {
    let h = 0, c = 0;
    for (let k = t - 11; k <= t; k++) { if (hits[k] !== null) { c++; h += hits[k]; } }
    if (c >= 3) rolling[t] = Math.round(h / c * 100);
  }
  let H = 0, C = 0;
  hits.forEach(v => { if (v !== null) { C++; H += v; } });
  return { rolling: rolling, overall: C > 0 ? Math.round(H / C * 100) : null, signals: C };
}

