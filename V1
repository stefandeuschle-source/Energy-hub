  /* sliders */
  .ctl-row { display: flex; align-items: center; gap: 12px; margin: 10px 0; font-size: 12px; }
  .ctl-row label { width: 220px; font-weight: 600; color: var(--mp-dark); }
  .ctl-row input[type=range] { flex: 1; accent-color: var(--mp-teal); }
  .ctl-row .ctl-val { width: 52px; text-align: right; font-weight: 700; color: var(--mp-teal); }

  .disclaimer {
    background: var(--mp-cream); border: 1px solid #e8dfc8; border-radius: 8px;
    padding: 12px 16px; font-size: 11.5px; color: #6b5d3a; line-height: 1.6; margin-top: 22px;
  }
  .footnote { font-size: 10.5px; color: var(--mp-grey); margin-top: 14px; line-height: 1.6; }
  .def-block { margin-top: 10px; border-top: 2px solid var(--mp-lightgrey); padding-top: 9px; }
  .def-row { display: flex; gap: 8px; margin-top: 6px; font-size: 11.5px; line-height: 1.55; color: #3d5a75; }
  .def-row .def-key {
    min-width: 92px; font-size: 9px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.8px; color: var(--mp-teal); padding-top: 2px;
  }
  .def-row code {
    font-family: 'Consolas', 'Menlo', monospace; font-size: 11px;
    background: var(--mp-lightgrey); padding: 1px 5px; border-radius: 4px; color: var(--mp-dark);
